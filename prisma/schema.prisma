generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  emailVerified        DateTime?
  name                 String?
  image                String?
  password             String?
  homeAddress          String?
  homeLat              Float?
  homeLng              Float?
  timezone             String               @default("America/New_York")
  units                String               @default("imperial")
  seasonBudget         Float?
  defaultEventType     String?
  calendarProvider     String?
  calendarId           String?
  calendarSyncEnabled  Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  accounts             Account[]
  sessions             Session[]
  cars                 Car[]
  events               Event[]
  parts                Part[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Car {
  id               String             @id @default(cuid())
  userId           String
  nickname         String?
  year             Int
  make             String
  model            String
  trim             String?
  color            String?
  vin              String?
  purchaseDate     DateTime?
  purchasePrice    Float?
  currentOdometer  Int?
  primaryUse       String?
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mods             Mod[]
  wishlistItems    WishlistItem[]
  parts            Part[]
  maintenanceEntries MaintenanceEntry[]
  events           Event[]
  runs             Run[]
  tireSets         TireSet[]
  brakeSets        BrakeSet[]
  suspensionSetups SuspensionSetup[]
  expenses         Expense[]
}

model Mod {
  id              String   @id @default(cuid())
  carId           String
  name            String
  category        String
  brand           String?
  partNumber      String?
  installDate     DateTime?
  installedBy     String?
  shopName        String?
  cost            Float?
  odometerAtInstall Int?
  receiptUrl      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  car             Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model WishlistItem {
  id            String   @id @default(cuid())
  carId         String
  name          String
  brand         String?
  category      String?
  estimatedCost Float?
  priority      String   @default("Medium")
  sourceUrl     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  car           Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model MaintenanceEntry {
  id                String    @id @default(cuid())
  carId             String
  serviceType       String
  customServiceName String?
  date              DateTime
  odometer          Int?
  performedBy       String?
  shopName          String?
  productBrand      String?
  productSpec       String?
  cost              Float?
  receiptUrl        String?
  notes             String?
  nextDueDate       DateTime?
  nextDueMileage    Int?
  snoozedUntil      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  car               Car                @relation(fields: [carId], references: [id], onDelete: Cascade)
  audits            MaintenanceAudit[]

  @@index([carId])
}

model MaintenanceAudit {
  id                   String           @id @default(cuid())
  maintenanceEntryId   String
  action               String
  previousSnoozedUntil DateTime?
  newSnoozedUntil      DateTime?
  createdAt            DateTime         @default(now())
  maintenanceEntry     MaintenanceEntry @relation(fields: [maintenanceEntryId], references: [id], onDelete: Cascade)

  @@index([maintenanceEntryId])
}

model Event {
  id                   String          @id @default(cuid())
  userId               String
  carId                String?
  name                 String
  type                 String
  organizingBody       String?
  startDate            DateTime
  endDate              DateTime?
  startTime            String?
  endTime              String?
  venueName            String?
  address              String?
  lat                  Float?
  lng                  Float?
  distanceFromHome     Float?
  driveTimeMinutes     Int?
  registrationStatus   String          @default("Interested")
  registrationDeadline DateTime?
  entryFee             Float?
  registrationUrl      String?
  runGroup             String?
  notes                String?
  calendarEventId      String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  car                  Car?            @relation(fields: [carId], references: [id])
  additionalCosts      AdditionalCost[]
  runs                 Run[]

  @@index([userId, startDate])
  @@index([userId, type])
}

model AdditionalCost {
  id          String   @id @default(cuid())
  eventId     String
  description String
  amount      Float
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Run {
  id              String           @id @default(cuid())
  eventId         String
  carId           String
  runNumber       Int
  rawTime         Float
  penalties       Json             @default("[]")
  adjustedTime    Float?
  isDnf           Boolean          @default(false)
  conditions      String[]
  tireSetup       String?
  tireSetId       String?
  brakeSetId      String?
  setupId         String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  car             Car              @relation(fields: [carId], references: [id])
  tireSet         TireSet?         @relation(fields: [tireSetId], references: [id])
  brakeSet        BrakeSet?        @relation(fields: [brakeSetId], references: [id])
  suspensionSetup SuspensionSetup? @relation(fields: [setupId], references: [id])

  @@index([eventId])
  @@index([carId])
  @@index([tireSetId])
  @@index([brakeSetId])
  @@index([setupId])
}

model TireSet {
  id            String          @id @default(cuid())
  carId         String
  brand         String
  model         String
  compound      String?
  frontSize     String
  rearSize      String?
  quantity      Int             @default(4)
  dotCode       String?
  maxHeatCycles Int?
  rearCost      Float?
  purchaseDate  DateTime?
  cost          Float?
  heatCycles    Int             @default(0)
  status        String          @default("Active")
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  car           Car             @relation(fields: [carId], references: [id], onDelete: Cascade)
  treadDepthLogs TreadDepthLog[]
  runs          Run[]

  @@index([carId])
}

model TreadDepthLog {
  id        String   @id @default(cuid())
  tireSetId String
  date      DateTime @default(now())
  depth     Float
  position  String?
  notes     String?
  createdAt DateTime @default(now())
  tireSet   TireSet  @relation(fields: [tireSetId], references: [id], onDelete: Cascade)

  @@index([tireSetId])
}

model BrakeSet {
  id           String   @id @default(cuid())
  carId        String
  position     String
  padBrand     String?
  padCompound  String?
  rotorBrand   String?
  rotorNotes   String?
  purchaseDate DateTime?
  cost         Float?
  heatCycles   Int      @default(0)
  wearRemaining Float?
  status       String   @default("Active")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  car          Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  runs         Run[]

  @@index([carId])
}

model SuspensionSetup {
  id                    String   @id @default(cuid())
  carId                 String
  name                  String
  isActive              Boolean  @default(false)
  camberFL              Float?
  camberFR              Float?
  camberRL              Float?
  camberRR              Float?
  toeFL                 Float?
  toeFR                 Float?
  toeRL                 Float?
  toeRR                 Float?
  casterFL              Float?
  casterFR              Float?
  springRateFront       Float?
  springRateRear        Float?
  rideHeightFront       Float?
  rideHeightRear        Float?
  damperClicksFrontComp Int?
  damperClicksFrontReb  Int?
  damperClicksRearComp  Int?
  damperClicksRearReb   Int?
  swayBarFront          String?
  swayBarRear           String?
  tirePressureFL        Float?
  tirePressureFR        Float?
  tirePressureRL        Float?
  tirePressureRR        Float?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  car                   Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  runs                  Run[]

  @@index([carId])
}

model Expense {
  id          String   @id @default(cuid())
  carId       String
  category    String
  date        DateTime
  amount      Float
  vendor      String?
  description String?
  receiptUrl  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
  @@index([carId, date])
}

// status: wishlist | stock | installed | archived
model Part {
  id           String    @id @default(cuid())
  userId       String
  carId        String?
  name         String
  manufacturer String?
  partNumber   String?
  category     String?
  description  String?
  productLink  String?
  status       String    @default("stock")
  price        Float?
  purchaseDate DateTime?
  vendor       String?
  quantity     Int       @default(1)
  notes        String?
  installedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  car          Car?      @relation(fields: [carId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([carId])
  @@map("parts")
}
