generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  emailVerified        DateTime?
  name                 String?
  image                String?
  password             String?
  homeAddress          String?
  homeLat              Float?
  homeLng              Float?
  timezone             String               @default("America/New_York")
  units                String               @default("imperial")
  seasonBudget         Float?
  calendarProvider     String?
  calendarId           String?
  calendarSyncEnabled  Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  accounts             Account[]
  sessions             Session[]
  cars                 Car[]
  events               Event[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Car {
  id               String             @id @default(cuid())
  userId           String
  nickname         String?
  year             Int
  make             String
  model            String
  trim             String?
  color            String?
  vin              String?
  purchaseDate     DateTime?
  purchasePrice    Float?
  currentOdometer  Int?
  primaryUse       String?
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mods             Mod[]
  wishlistItems    WishlistItem[]
  maintenanceEntries MaintenanceEntry[]
  events           Event[]
  runs             Run[]
}

model Mod {
  id              String   @id @default(cuid())
  carId           String
  name            String
  category        String
  brand           String?
  partNumber      String?
  installDate     DateTime?
  installedBy     String?
  shopName        String?
  cost            Float?
  odometerAtInstall Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  car             Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model WishlistItem {
  id            String   @id @default(cuid())
  carId         String
  name          String
  category      String?
  estimatedCost Float?
  priority      String   @default("Medium")
  sourceUrl     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  car           Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model MaintenanceEntry {
  id                String    @id @default(cuid())
  carId             String
  serviceType       String
  customServiceName String?
  date              DateTime
  odometer          Int?
  performedBy       String?
  shopName          String?
  productBrand      String?
  productSpec       String?
  cost              Float?
  notes             String?
  nextDueDate       DateTime?
  nextDueMileage    Int?
  snoozedUntil      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  car               Car                @relation(fields: [carId], references: [id], onDelete: Cascade)
  audits            MaintenanceAudit[]

  @@index([carId])
}

model MaintenanceAudit {
  id                   String           @id @default(cuid())
  maintenanceEntryId   String
  action               String
  previousSnoozedUntil DateTime?
  newSnoozedUntil      DateTime?
  createdAt            DateTime         @default(now())
  maintenanceEntry     MaintenanceEntry @relation(fields: [maintenanceEntryId], references: [id], onDelete: Cascade)

  @@index([maintenanceEntryId])
}

model Event {
  id                   String          @id @default(cuid())
  userId               String
  carId                String?
  name                 String
  type                 String
  organizingBody       String?
  startDate            DateTime
  endDate              DateTime?
  venueName            String?
  address              String?
  lat                  Float?
  lng                  Float?
  distanceFromHome     Float?
  driveTimeMinutes     Int?
  registrationStatus   String          @default("Interested")
  registrationDeadline DateTime?
  entryFee             Float?
  registrationUrl      String?
  runGroup             String?
  notes                String?
  calendarEventId      String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  car                  Car?            @relation(fields: [carId], references: [id])
  additionalCosts      AdditionalCost[]
  runs                 Run[]

  @@index([userId, startDate])
  @@index([userId, type])
}

model AdditionalCost {
  id          String   @id @default(cuid())
  eventId     String
  description String
  amount      Float
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Run {
  id           String   @id @default(cuid())
  eventId      String
  carId        String
  runNumber    Int
  rawTime      Float
  penalties    Json     @default("[]")
  adjustedTime Float?
  isDnf        Boolean  @default(false)
  conditions   String[]
  tireSetup    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  car          Car      @relation(fields: [carId], references: [id])

  @@index([eventId])
  @@index([carId])
}
